<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Camera Preview (Background) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/qr_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Dimming overlay with scan window cutout -->
    <com.fadcam.ui.miniapps.ScanOverlayView
        android:id="@+id/qr_dim_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header Bar -->
    <LinearLayout
        android:id="@+id/qr_header_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/qr_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/button_close"
            android:tint="@android:color/white"
            android:background="@drawable/settings_home_row_bg"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <com.fadcam.ui.utils.AnimatedTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="@string/mini_app_qr_scanner_title"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

        </LinearLayout>

        <ImageView
            android:id="@+id/qr_torch"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_flashlight_off"
            android:contentDescription="@string/button_torch"
            android:tint="@android:color/white"
            android:background="@drawable/settings_home_row_bg"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Scan Frame Container with Premium Border -->
    <FrameLayout
        android:id="@+id/qr_scan_container"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Outer glow effect -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_scan_frame_glow"
            android:alpha="0.15" />

        <!-- Scan frame border -->
        <View
            android:id="@+id/qr_scan_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/qr_scan_frame_premium" />

        <!-- Animated scan line -->
        <View
            android:id="@+id/qr_scan_line"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_scan_line_premium"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Auto-Save Info Chip -->
    <com.google.android.material.chip.Chip
        android:id="@+id/qr_auto_save_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Auto-saved to Records"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        app:chipBackgroundColor="#1AFFFFFF"
        app:chipStrokeColor="@android:color/white"
        app:chipStrokeWidth="0.5dp"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@id/qr_scan_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Result Container (Slide Up Animation) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/qr_result_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="32dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#1F1F1F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Result text -->
            <TextView
                android:id="@+id/qr_result_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="5"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2" />

            <!-- Hint text -->
            <TextView
                android:id="@+id/qr_hint_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Point camera at QR or barcode"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:spacing="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/qr_btn_copy"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/button_copy"
                    android:textSize="14sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@android:color/white"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/qr_btn_scan_again"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/button_scan_again"
                    android:textSize="14sp"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
